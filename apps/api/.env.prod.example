# API runtime + script env for prod (copy to apps/api/.env.prod)
CROP_ENV=prod
DATABASE_URL=
API_GATEWAY_URL=https://api.cropcopilot.app
NEXT_PUBLIC_API_GATEWAY_URL=https://api.cropcopilot.app
APP_BASE_URL=https://www.cropcopilot.app

# Model + retrieval
RECOMMENDATION_MODEL_PROVIDERS=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
REQUIRE_MODEL_OUTPUT=true

# Premium
OPENWEATHER_API_KEY=
PRICING_SEARCH_PROVIDER=perplexity
PERPLEXITY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Billing (live keys for prod)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_WEBHOOK_SECRET=
ALLOW_BILLING_SIMULATION=false
BILLING_PORTAL_RETURN_URL=https://www.cropcopilot.app/settings/billing

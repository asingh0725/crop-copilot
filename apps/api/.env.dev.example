# API runtime + script env for dev (copy to apps/api/.env.dev)
CROP_ENV=dev
DATABASE_URL=
API_GATEWAY_URL=http://localhost:3000
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Model + retrieval
RECOMMENDATION_MODEL_PROVIDERS=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=

# Premium
OPENWEATHER_API_KEY=
PREMIUM_PRICING_LOOKUP_MODE=live_then_estimated
PREMIUM_PRICING_ALLOW_ESTIMATED_FALLBACK=true
PRICING_SEARCH_PROVIDER=perplexity
PERPLEXITY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Billing (test keys for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_WEBHOOK_SECRET=
ALLOW_BILLING_SIMULATION=true
BILLING_PORTAL_RETURN_URL=http://localhost:3000/settings/billing

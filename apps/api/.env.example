# Canonical setup:
#   cp apps/api/.env.dev.example apps/api/.env.dev
#   cp apps/api/.env.prod.example apps/api/.env.prod

# Runtime environment selector
CROP_ENV=dev

# Core connectivity
DATABASE_URL=
APP_BASE_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:3000
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3000

# Auth verifier (set Cognito OR Supabase vars)
COGNITO_REGION=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# LLM/retrieval
RECOMMENDATION_MODEL_PROVIDERS=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Premium + billing
OPENWEATHER_API_KEY=
PREMIUM_PRICING_LOOKUP_MODE=live_then_estimated
PREMIUM_PRICING_ALLOW_ESTIMATED_FALLBACK=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
